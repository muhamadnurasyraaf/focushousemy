// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String
  role           UserRole        @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  repairRequests RepairRequest[]
}

model Accessory {
  id          String               @id @default(cuid())
  name        String
  description String?
  category    String?
  quantity    Int                  @default(1)
  pricePerDay Decimal              @db.Decimal(10, 2)
  images      String[]
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  comboItems  AccessoryComboItem[]
}

model AccessoryCombo {
  id          String               @id @default(cuid())
  name        String
  description String?
  price       Decimal              @db.Decimal(10, 2)
  images      String[]
  isActive    Boolean              @default(true)
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       AccessoryComboItem[]

  @@index([isActive])
  @@index([order])
}

model AccessoryComboItem {
  id          String         @id @default(cuid())
  comboId     String
  combo       AccessoryCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  accessoryId String
  accessory   Accessory      @relation(fields: [accessoryId], references: [id], onDelete: Cascade)
  quantity    Int            @default(1)
  createdAt   DateTime       @default(now())

  @@index([comboId])
  @@index([accessoryId])
}

model RepairService {
  id          String          @id @default(cuid())
  name        String
  description String?
  basePrice   Decimal         @db.Decimal(10, 2)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  requests    RepairRequest[]
}

model RepairRequest {
  id               String              @id @default(cuid())
  serviceId        String
  service          RepairService       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerName     String
  customerEmail    String
  customerPhone    String?
  issueDescription String
  estimatedPrice   Decimal?            @db.Decimal(10, 2)
  finalPrice       Decimal?            @db.Decimal(10, 2)
  status           RepairRequestStatus @default(PENDING)
  notes            String?
  cancelReason     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([serviceId])
  @@index([userId])
  @@index([status])
}

enum UserRole {
  ADMIN
  USER
}

enum RepairRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model SiteConfig {
  id                  String   @id @default(cuid())
  heroBackgroundImage String?
  contactNumber       String?
  instagram           String?
  facebook            String?
  address             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PhotographyPage {
  id           String                   @id @default(cuid())
  heroTitle    String                   @default("Photography & Videography")
  heroSubtitle String?
  heroImage    String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  sections     PhotographyPageSection[]
}

model PhotographyPageSection {
  id        String          @id @default(cuid())
  pageId    String
  page      PhotographyPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title     String
  content   String?         @db.Text
  images    String[]
  layout    String          @default("IMAGE_LEFT") // IMAGE_LEFT, IMAGE_RIGHT, FULL_WIDTH, GALLERY
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([pageId])
  @@index([order])
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  blocks    Json     @default("[]")
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhotographyService {
  id            String   @id @default(cuid())
  title         String
  description   String?
  details       String?  @db.Text
  price         Decimal? @db.Decimal(10, 2)
  duration      String?
  mainImage     String?
  galleryImages String[]
  videos        String[]
  features      String[]
  category      String   @default("PHOTOGRAPHY")
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([order])
}
